// GrowMate Prisma Schema
// еЁҙж»„жҹЁйҗӘдјҙејёй‘ёз”өвӮ¬оҲһж•Қе§ҳиҫЁжҡҸй–№ж’®ж”ұйҸҶзҶје№‘?й–і?AIжҝЎжҘӢзөҫйЎў?й–і?й–ёж„¬жҮҺйЎ”?й–і?зјҒвӮ¬йҺҜСғйҡҳ й–і?йҹ«еӣ§е•°йҺ®е©Үжғ„йҺҙзӮІР‘

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String
  bio          String?
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  journalEntries JournalEntry[]
  moodLogs       MoodLog[]
  posts          Post[]
  comments       Comment[]
  courseProgress CourseProgress[]
  aiProfile      AiProfile?
  checkIns       CheckIn[]
  diarySchedules DiarySchedule[]
}

// зјҒжҘҠе…ӣз»”еҜёд»ҰйҚҢпёҫзӘ—еЁ‘ж“ғдәҷе§№еӨӢзЁүйҸ„еҝЈжҪҺйҗ дҪ№жҫҳзјҚ?
model JournalEntry {
  id             String   @id @default(cuid())
  userId         String
  title          String
  content        String
  mood           Int?     // 1-5
  tags           String   @default("[]") // flat tag names JSON array
  isPrivate      Boolean  @default(true)
  timePeriod     String   @default("") // ж¶“е©ӮеҙҚ|ж¶“е¬ӘеҙҚ|йҸ…ж°«з¬Ӯ|еЁЈеҚһоҷҒ
  analysisStatus String   @default("done") // pending|done|failed
  analysisJson   String   @default("{}") // multi-layer AI tags + schedule candidate
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedules DiarySchedule[]

  @@index([userId, createdAt])
}

// еЁҙж»…е„Өйҗ—?йҹ«еӣ§е•°йҺ®е©Үж•Қе§ҳо…һеү°зјӮдҫҮдәқжҫ§п№ӮеҙЎ?
model MoodLog {
  id         String   @id @default(cuid())
  userId     String
  score      Int      // 1-5 й–№оҲҡжҮҗйҚ—еәЁеҙҡ?
  energy     Int      @default(3) // 1-5 зјҒоҶҪе„іжҝ®?
  stress     Int      @default(3) // 1-5 й–ёжЁәоғ…жҝ®?
  note       String?
  riskLevel  String   @default("normal") // normal | watch | alert
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// зјҒжҘҠе…ӣз»Ёв•ғд»ҰйҚҢпёҫзӘ—AI еЁ‘ж“ғдәҷе§№еӨҠоӣјй”қе—©ж”і
model AiProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  summary         String   @default("")
  personalityTags String   @default("[]") // JSON
  strengths       String   @default("[]")
  weaknesses      String   @default("[]")
  emotionPattern  String   @default("")
  goals           String   @default("[]")
  rawFeatures     String   @default("{}") // JSON features blob
  lastAnalyzedAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// зјҒжҘҠеүҷеЁІж’¶д»ҰйҚҢпёҫзӘ—й–ёг„ҘеҖ»еЁІи·ЁзІҲйҺҜСғйҡҳ
model Community {
  id          String @id @default(cuid())
  slug        String @unique
  name        String
  description String
  icon        String @default("users")
  tone        String @default("supportive") // supportive | healing | training | learning
  posts       Post[]
}

model Post {
  id          String   @id @default(cuid())
  communityId String
  authorId    String
  title       String
  content     String
  isAnonymous Boolean  @default(false)
  likeCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments  Comment[]

  @@index([communityId, createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

// зјҒжҘҠе…ӣз»—дҪәд»ҰйҚҢпёҫзӘ—еЁ‘ж’ҙжҢ·з»—зҶјеҙҳйҚӣо…§е•Үйҗ СғоғҲйҚҸ?
model CourseModule {
  id          String   @id @default(cuid())
  slug        String   @unique // fitness | nutrition | tech | mental
  name        String
  description String
  courses     Course[]
}

model Course {
  id          String @id @default(cuid())
  moduleId    String
  title       String
  summary     String
  level       String @default("beginner") // beginner | intermediate | advanced
  durationMin Int    @default(30)
  lessons     String @default("[]") // JSON array of {title, content, codeExamples, exercises}
  order       Int    @default(0)

  module   CourseModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress CourseProgress[]

  @@index([moduleId, order])
}

model CourseProgress {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  status      String    @default("not_started") // not_started | in_progress | completed
  notes       String    @default("") // йҗҺж¶ізјҡз»ЎеӢӯзІӯйҸғеӣ¶е”¶
  studyTime   Int       @default(0) // зјҒйі–еһөйЎ“е“ҘвӮ¬ж¶ізјҡз»ЎеӢҜеј®йҚ«жӣҹжҜҗй–ҝж¶ҳзүҸйЎ«жҘ…ж•Қ?
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

// й–№еһ«жҢёе®•йҒҚж•Қе§ҳоӮӨз§јй–ј?йҗҺж¶ізјҡз»Ў?еҰӨжҘҠеҷЈйЎҘ?
model CheckIn {
  id        String   @id @default(cuid())
  userId    String
  type      String   // fitness | nutrition | tech | mental | custom
  title     String
  note      String?
  value     Float?
  unit      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, createdAt])
}

// Diary schedule created from multi-layer diary analysis (PR2)
model DiarySchedule {
  id                    String    @id @default(cuid())
  userId                String
  journalEntryId        String?
  title                 String
  startAt               DateTime
  endAt                 DateTime?
  location              String?
  note                  String?
  source                String    @default("diary")
  reminderOffsetMinutes Int       @default(15)
  createdAt             DateTime  @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  journal JournalEntry?  @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)

  @@index([userId, startAt])
}