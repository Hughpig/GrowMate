// GrowMate Prisma Schema
// 娴滄柨鐪伴弸鑸电€敍姘辨暏閹撮攱鏆熼幑?閳?AI濡楋絾顢?閳?閸愬懎顔?閳?缁€鎯у隘 閳?韫囧啰鎮婇惄鎴炲Б

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  displayName  String
  bio          String?
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  journalEntries JournalEntry[]
  moodLogs       MoodLog[]
  posts          Post[]
  comments       Comment[]
  courseProgress CourseProgress[]
  aiProfile      AiProfile?
  checkIns       CheckIn[]
  diarySchedules DiarySchedule[]
  trainingGoals  TrainingGoal[]
  trainingPlans  TrainingPlanRecord[]
}

// 缁楊兛绔寸仦鍌︾窗娑擃亙姹夋稉鏄忣潎鐠佹澘缍?
model JournalEntry {
  id             String   @id @default(cuid())
  userId         String
  title          String
  content        String
  mood           Int?     // 1-5
  tags           String   @default("[]") // flat tag names JSON array
  isPrivate      Boolean  @default(true)
  timePeriod     String   @default("") // 涓婂崍|涓嬪崍|鏅氫笂|娣卞
  analysisStatus String   @default("done") // pending|done|failed
  analysisJson   String   @default("{}") // multi-layer AI tags + schedule candidate
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedules DiarySchedule[]

  @@index([userId, createdAt])
}

// 娴滅儤鐗?韫囧啰鎮婇敍姘剰缂侇亝澧﹂崡?
model MoodLog {
  id         String   @id @default(cuid())
  userId     String
  score      Int      // 1-5 閹懐鍗庨崚?
  energy     Int      @default(3) // 1-5 缁儳濮?
  stress     Int      @default(3) // 1-5 閸樺濮?
  note       String?
  riskLevel  String   @default("normal") // normal | watch | alert
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// 缁楊兛绨╃仦鍌︾窗AI 娑擃亙姹夊锝嗩攳
model AiProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  summary         String   @default("")
  personalityTags String   @default("[]") // JSON
  strengths       String   @default("[]")
  weaknesses      String   @default("[]")
  emotionPattern  String   @default("")
  goals           String   @default("[]")
  rawFeatures     String   @default("{}") // JSON features blob
  lastAnalyzedAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 缁楊剙娲撶仦鍌︾窗閸ㄥ倻娲跨粈鎯у隘
model Community {
  id          String @id @default(cuid())
  slug        String @unique
  name        String
  description String
  icon        String @default("users")
  tone        String @default("supportive") // supportive | healing | training | learning
  posts       Post[]
}

model Post {
  id          String   @id @default(cuid())
  communityId String
  authorId    String
  title       String
  content     String
  isAnonymous Boolean  @default(false)
  likeCount   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  community Community @relation(fields: [communityId], references: [id], onDelete: Cascade)
  author    User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  comments  Comment[]

  @@index([communityId, createdAt])
}

model Comment {
  id        String   @id @default(cuid())
  postId    String
  authorId  String
  content   String
  createdAt DateTime @default(now())

  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
}

// 缁楊兛绗佺仦鍌︾窗娑撴挷绗熼崘鍛啇鐠у鍏?
model CourseModule {
  id          String   @id @default(cuid())
  slug        String   @unique // fitness | nutrition | tech | mental
  name        String
  description String
  courses     Course[]
}

model Course {
  id          String @id @default(cuid())
  moduleId    String
  title       String
  summary     String
  level       String @default("beginner") // beginner | intermediate | advanced
  durationMin Int    @default(30)
  lessons     String @default("[]") // JSON array of {title, content, codeExamples, exercises}
  order       Int    @default(0)

  module   CourseModule     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  progress CourseProgress[]

  @@index([moduleId, order])
}

model CourseProgress {
  id          String    @id @default(cuid())
  userId      String
  courseId    String
  status      String    @default("not_started") // not_started | in_progress | completed
  notes       String    @default("") // 鐎涳缚绡勭粭鏃囶唶
  studyTime   Int       @default(0) // 缁鳖垵顓哥€涳缚绡勯弮鍫曟毐閿涘牏顫楅敍?
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([userId, courseId])
}

// 閹垫挸宕遍敍姘秼閼?鐎涳缚绡?妤楊噣顥?
model CheckIn {
  id        String   @id @default(cuid())
  userId    String
  type      String   // fitness | nutrition | tech | mental | custom
  title     String
  note      String?
  value     Float?
  unit      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, createdAt])
}

// Diary schedule created from multi-layer diary analysis (PR2)
model DiarySchedule {
  id                    String    @id @default(cuid())
  userId                String
  journalEntryId        String?
  title                 String
  startAt               DateTime
  endAt                 DateTime?
  location              String?
  note                  String?
  source                String    @default("diary")
  reminderOffsetMinutes Int       @default(15)
  createdAt             DateTime  @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  journal JournalEntry?  @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)

  @@index([userId, startAt])
}

// Personal training assistant
model TrainingGoal {
  id                 String   @id @default(cuid())
  userId             String
  type               String
  targetWeightLoss   Float?
  timelineWeeks      Int?
  focusAreas         String   @default("[]")
  uncomfortableParts String   @default("[]")
  customGoalText     String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt])
}

model TrainingPlanRecord {
  id                String   @id @default(cuid())
  userId            String
  name              String
  type              String
  durationMinutes   Int
  intensity         String
  adjustmentReason  String   @default("")
  exercisesJson     String   @default("[]")
  wellnessJson      String   @default("{}")
  citationsJson     String   @default("[]")
  goalSnapshotJson  String   @default("{}")
  dailyStatusJson   String   @default("{}")
  source            String   @default("local")
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
